# ==========================================
# APIs & Models
# ==========================================
GOOGLE_API_KEY=your_google_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ==========================================
# Ollama Settings
# ==========================================
# Set to true to use local or cloud Ollama models
USE_OLLAMA=true
OLLAMA_MODEL=qwen3.5:397b-cloud

# For local use:
# OLLAMA_BASE_URL=http://localhost:11434

# For Ollama Cloud models:
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here

# ==========================================
# Database Configuration (Remote)
# ==========================================
# Note: Database is hosted on a remote machine, NOT localhost.
# Requires asyncpg compatible URL driver (e.g., postgresql+asyncpg://)
DATABASE_URL=postgresql+asyncpg://user:password@100.120.x.x:5432/dbname
